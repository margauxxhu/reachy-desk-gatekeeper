# Copy to .env and fill in your values
DISCORD_TOKEN=your_bot_token_here
DISCORD_GUILD_ID=your_guild_id_here   # optional: scopes slash commands to one server (faster sync)

# Camera
CAMERA_INDEX=0                         # OpenCV device index (0 = default webcam)

# Reachy Mini
REACHY_HOST=localhost                   # IP/hostname of the Reachy Mini
REACHY_PORT=8000
